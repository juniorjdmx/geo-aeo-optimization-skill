{
  "_comment": "JSON-LD templates for GEO/AEO. Copy the needed block, fill it with real data, and insert it into server-rendered HTML. Validate at validator.schema.org. Remove any _comment fields. Ideally connect page entities via @graph (see example at the end).",

  "FAQPage": {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "First frequently asked question, in natural language?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Direct answer in plain text, matching the visible page content."
        }
      }
    ]
  },

  "QAPage": {
    "@context": "https://schema.org",
    "@type": "QAPage",
    "mainEntity": {
      "@type": "Question",
      "name": "The central question for this page?",
      "answerCount": 1,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The best answer to the question, in plain text."
      }
    }
  },

  "Organization": {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Company Name",
    "url": "https://site.com",
    "logo": "https://site.com/logo.png",
    "description": "What the company does, in one factual sentence.",
    "sameAs": [
      "https://www.wikidata.org/wiki/Q00000000",
      "https://en.wikipedia.org/wiki/Company_Name",
      "https://www.linkedin.com/company/company",
      "https://www.crunchbase.com/organization/company"
    ]
  },

  "Person_author": {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Author Full Name",
    "jobTitle": "Role or specialty",
    "description": "Summary of the author's expertise and relevant experience.",
    "worksFor": { "@type": "Organization", "name": "Company Name" },
    "knowsAbout": ["Topic 1", "Topic 2", "Topic 3"],
    "alumniOf": "Education institution",
    "url": "https://site.com/author/name",
    "sameAs": [
      "https://www.linkedin.com/in/perfil",
      "https://orcid.org/0000-0000-0000-0000"
    ]
  },

  "Article": {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Article title, ideally phrased as a question",
    "description": "Short article summary.",
    "datePublished": "2026-01-01",
    "dateModified": "2026-05-20",
    "author": { "@type": "Person", "name": "Author Name", "url": "https://site.com/author/name" },
    "publisher": {
      "@type": "Organization",
      "name": "Company Name",
      "logo": { "@type": "ImageObject", "url": "https://site.com/logo.png" }
    }
  },

  "Product": {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Product Name",
    "sku": "SKU-123",
    "description": "Product description.",
    "image": "https://site.com/produto.jpg",
    "offers": {
      "@type": "Offer",
      "price": "189.00",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://site.com/produto"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "127"
    }
  },

  "HowTo": {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to do X",
    "step": [
      { "@type": "HowToStep", "name": "Step 1", "text": "Step 1 instruction." },
      { "@type": "HowToStep", "name": "Step 2", "text": "Step 2 instruction." }
    ]
  },

  "LocalBusiness": {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Business Name",
    "image": "https://site.com/fachada.jpg",
    "telephone": "+1-000-000-0000",
    "url": "https://site.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Example Street, 100",
      "addressLocality": "City",
      "addressRegion": "State",
      "postalCode": "00000-000",
      "addressCountry": "US"
    },
    "openingHours": "Mo-Fr 09:00-18:00"
  },

  "Review": {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": { "@type": "Organization", "name": "Company Name" },
    "author": { "@type": "Person", "name": "Customer Name" },
    "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
    "reviewBody": "A real customer testimonial."
  },

  "BreadcrumbList": {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://site.com" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://site.com/services" },
      { "@type": "ListItem", "position": 3, "name": "Current page", "item": "https://site.com/services/page" }
    ]
  },

  "VideoObject": {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": "Video title, phrased as a question",
    "description": "Summary of the video content in text.",
    "thumbnailUrl": "https://site.com/thumb.jpg",
    "uploadDate": "2026-01-01",
    "duration": "PT5M30S",
    "embedUrl": "https://www.youtube.com/embed/ID",
    "transcript": "Full video transcript in plain text."
  },

  "_graph_example": {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://site.com/#org",
        "name": "Company Name",
        "url": "https://site.com",
        "sameAs": ["https://www.wikidata.org/wiki/Q00000000"]
      },
      {
        "@type": "Person",
        "@id": "https://site.com/#author-name",
        "name": "Author Name",
        "knowsAbout": ["Topic 1"]
      },
      {
        "@type": "Article",
        "@id": "https://site.com/pagina/#article",
        "headline": "Article title",
        "datePublished": "2026-01-01",
        "dateModified": "2026-05-20",
        "author": { "@id": "https://site.com/#author-name" },
        "publisher": { "@id": "https://site.com/#org" }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://site.com" },
          { "@type": "ListItem", "position": 2, "name": "Page", "item": "https://site.com/page" }
        ]
      }
    ]
  }
}
